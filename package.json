{
  "name": "@autokindler/root",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:docker": "docker compose -f infra/docker-compose.yml up -d",
    "db:push": "pnpm --filter @autokindler/db run push",
    "db:studio": "pnpm --filter @autokindler/db run studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}