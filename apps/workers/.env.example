# Copy to .env — all defaults point to LocalStack, no real credentials needed for local dev

DATABASE_URL=postgres://autokindler:autokindler@localhost:5432/autokindler

# SQS
SQS_ENDPOINT=http://localhost:4566
SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/autokindler-deliveries
AWS_REGION=us-east-1

# SES / SMTP
SES_SMTP_HOST=localhost
SES_SMTP_PORT=4566
SES_SMTP_USER=
SES_SMTP_PASSWORD=
SES_FROM_EMAIL=autokindler@openfolie.org

# File cache
CACHE_DIR=/tmp/autokindler-cache
CACHE_TTL_DAYS=3

# Timeouts (seconds)
DOWNLOAD_TIMEOUT=60
CONVERSION_TIMEOUT=120
EMAIL_TIMEOUT=30
JOB_TIMEOUT=300
