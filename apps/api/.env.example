# Database
DATABASE_URL=postgres://autokindler:autokindler@localhost:5432/autokindler

# AWS SQS (LocalStack for local dev)
SQS_ENDPOINT=http://localhost:4566
SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/autokindler-deliveries
AWS_REGION=us-east-1

# Server
PORT=3000

# GitHub OAuth (create at https://github.com/settings/developers -> OAuth Apps -> New OAuth App)
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT (generate a random secret for production, min 32 chars)
JWT_SECRET=dev-secret-change-me-in-production-at-least-32-chars
JWT_EXPIRY=7d

# App URL (used for OAuth callback redirect)
APP_URL=http://localhost:3000
